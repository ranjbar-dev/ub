{
  "name": "ub_admin",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@date-io/date-fns": "2.6.2",
    "@material-ui/core": "4.12.4",
    "@material-ui/icons": "4.11.3",
    "@material-ui/lab": "4.0.0-alpha.55",
    "@material-ui/pickers": "3.2.10",
    "@reduxjs/toolkit": "1.3.6",
    "@testing-library/jest-dom": "5.17.0",
    "@testing-library/react": "12.1.5",
    "@types/fontfaceobserver": "0.0.6",
    "@types/history": "4.7.6",
    "@types/jest": "27.5.0",
    "@types/node": "18.19.0",
    "@types/react": "17.0.91",
    "@types/react-cropper": "1.3.0",
    "@types/react-dom": "17.0.26",
    "@types/react-helmet": "6.0.0",
    "@types/react-redux": "7.1.9",
    "@types/react-router-dom": "5.1.5",
    "@types/react-test-renderer": "17.0.9",
    "@types/styled-components": "5.1.0",
    "@types/testing-library__jest-dom": "5.9.1",
    "@types/webpack-env": "1.15.2",
    "@vaadin/vaadin-date-picker": "4.2.0",
    "ag-grid-community": "23.2.0",
    "ag-grid-react": "23.2.0",
    "ajv": "8.18.0",
    "animejs": "3.2.0",
    "classnames": "2.2.6",
    "connected-react-router": "6.8.0",
    "cross-env": "7.0.2",
    "date-fns": "2.14.0",
    "fontfaceobserver": "2.1.0",
    "history": "4.10.1",
    "husky": "4.2.5",
    "i18next": "19.4.5",
    "i18next-browser-languagedetector": "4.2.0",
    "jest-styled-components": "7.0.2",
    "lint-staged": "10.2.9",
    "node-plop": "0.25.0",
    "notistack": "0.9.17",
    "plop": "2.6.0",
    "rc-viewer": "0.0.9",
    "react": "17.0.2",
    "react-anime": "3.0.3",
    "react-app-polyfill": "1.0.6",
    "react-cool-dimensions": "1.1.3",
    "react-cropper": "1.3.0",
    "react-dom": "17.0.2",
    "react-helmet-async": "1.0.6",
    "react-i18next": "11.5.0",
    "react-new-window": "0.1.2",
    "react-redux": "7.2.0",
    "react-resize-detector": "5.0.7",
    "react-router-dom": "5.2.0",
    "react-scripts": "5.0.1",
    "react-test-renderer": "17.0.2",
    "react-viewer": "3.2.1",
    "redux-injectors": "1.3.0",
    "redux-saga": "1.1.3",
    "replace-in-file": "6.1.0",
    "sanitize.css": "11.0.1",
    "sass": "1.43.4",
    "serve": "14.2.4",
    "shelljs": "0.8.5",
    "styled-components": "5.1.1",
    "stylelint": "13.6.0",
    "stylelint-config-recommended": "3.0.0",
    "stylelint-config-styled-components": "0.1.1",
    "stylelint-processor-styled-components": "1.10.0",
    "ts-node": "8.10.2",
    "typescript": "5.4.5"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "test:generators": "ts-node --project=./internals/ts-node.tsconfig.json ./internals/testing/test-generators.ts",
    "start:prod": "yarn build && serve -s build",
    "checkTs": "tsc --noEmit",
    "eslint": "eslint --ext js,ts,tsx",
    "lint": "yarn eslint -- src",
    "lint:fix": "yarn eslint -- --fix src",
    "lint:css": "stylelint src/**/*.css",
    "generate": "cross-env TS_NODE_PROJECT='./internals/ts-node.tsconfig.json' plop --plopfile internals/generators/plopfile.ts",
    "cleanAndSetup": "ts-node --project=./internals/ts-node.tsconfig.json ./internals/scripts/clean.ts"
  },
  "vaadin": {
    "disableUsageStatistics": true
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "engines": {
    "npm": ">=8.0.0",
    "node": ">=18.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "npm run eslint -- --fix"
    ]
  },
  "husky(remove-everything-in-these-parentheses.See-the-issue-#29)": {
    "hooks": {
      "pre-commit": "npm run checkTs && lint-staged"
    }
  },
  "jest": {
    "moduleNameMapper": {
      "@vaadin/vaadin-date-picker": "<rootDir>/src/__mocks__/vaadin-date-picker.js"
    },
    "collectCoverageFrom": [
      "src/**/*.{js,jsx,ts,tsx}",
      "!src/**/*/*.d.ts",
      "!src/**/*/Loadable.{js,jsx,ts,tsx}",
      "!src/**/*/types.ts",
      "!src/index.tsx",
      "!src/serviceWorker.ts"
    ],
    "coverageThreshold": {
      "global": {
        "branches": 90,
        "functions": 90,
        "lines": 90,
        "statements": 90
      }
    }
  },
  "eslintConfig": {
    "extends": [
      "react-app"
    ],
    "plugins": [
      "import"
    ],
    "rules": {
      "import/order": [
        "warn",
        {
          "groups": [
            [
              "builtin",
              "external"
            ],
            "internal",
            [
              "parent",
              "sibling",
              "index"
            ]
          ],
          "newlines-between": "always",
          "alphabetize": {
            "order": "asc",
            "caseInsensitive": true
          }
        }
      ]
    }
  },
  "packageManager": "yarn@1.22.22+sha512.a6b2f7906b721bba3d67d4aff083df04dad64c399707841b7acf00f6b133b7ac24255f2652fa22ae3534329dc6180534e98d17432037ff6fd140556e2bb3137e",
  "devDependencies": {
    "eslint-plugin-import": "2.32.0",
    "svgo": "4.0.1"
  },
  "resolutions": {
    "@types/react": "17.0.91",
    "@types/react-router": "5.1.8"
  }
}
