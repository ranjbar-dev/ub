# ub-app-main Environment Variables
# These are passed via --dart-define during build

# Environment: DEV or PRODUCTION
# Currently hardcoded in lib/utils/environment/ubEnv.dart
ENV=PRODUCTION

# App version (auto-read from pubspec.yaml by build scripts)
VERSION=1.1.7+10

# API Base URL (configured in lib/services/constants.dart)
# DEV: https://dev-app.unitedbit.com/api/v1/
# PROD: https://app.unitedbit.com/api/v1/

# MQTT Broker (configured in lib/services/constants.dart)
# DEV: wss://dev-app.unitedbit.com:8443
# PROD: wss://app.unitedbit.com:8443

# Flutter SDK (for local development)
# Requires Dart SDK >=2.11.0 <3.0.0 (Flutter 2.10.5 recommended)
# Use FVM or similar tool to manage multiple Flutter versions
