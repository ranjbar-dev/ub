# ub-exchange-cli-main — Required Environment Variables
# Copy to .env and fill in values for your environment.
# Viper reads these with prefix UBEXCHANGE_ (dots become underscores).

# Database
UBEXCHANGE_DB_DSN=exchange_user:exchange_pass@tcp(db:3306)/exchange_db?parseTime=true

# Redis
UBEXCHANGE_REDIS_PASSWORD=

# RabbitMQ
UBEXCHANGE_RABBITMQ_DSN=amqp://rabbitmquser:password@rabbitmq:5672/

# Centrifugo
UBEXCHANGE_CENTRIFUGO_API_KEY=your-api-key
UBEXCHANGE_CENTRIFUGO_TOKEN_HMAC_SECRET=your-secret-key

# reCAPTCHA
UBEXCHANGE_RECAPTCHA_SECRETKEY=your-recaptcha-secret
UBEXCHANGE_RECAPTCHA_ANDROIDSECRETKEY=your-android-recaptcha-secret

# JWT
UBEXCHANGE_JWT_PASSPHRASE=your-jwt-passphrase

# Wallet Service
UBEXCHANGE_WALLET_HOST=http://wallet-service:8080
UBEXCHANGE_WALLET_USERNAME=wallet_user
UBEXCHANGE_WALLET_PASSWORD=wallet_pass

# Sentry (optional)
UBEXCHANGE_SENTRY_DSN=

# Exchange Environment (prod/dev/test)
UBEXCHANGE_EXCHANGE_ENVIRONMENT=dev
