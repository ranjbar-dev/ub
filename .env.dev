# ─────────────────────────────────────────────────────────────
# UnitedBit Exchange — Development Environment Variables
# Used by docker-compose.dev.yml
# Copy to .env and modify as needed
# ─────────────────────────────────────────────────────────────

# ── MariaDB ─────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=exchange_db
MYSQL_USER=exchange_user
MYSQL_PASSWORD=exchange_pass

# ── RabbitMQ ────────────────────────────────────────────────
RABBITMQ_DEFAULT_USER=rabbitmquser
RABBITMQ_DEFAULT_PASS=some_password
RABBITMQ_DEFAULT_VHOST=/

# ── MongoDB (Communicator) ──────────────────────────────────
MONGO_ROOT_USERNAME=mongoadmin
MONGO_ROOT_PASSWORD=mongopass

# ── Communicator env vars (UBCOMMUNICATOR_ prefix) ──────────
UBCOMMUNICATOR_RABBITMQ_DSN=amqp://rabbitmquser:some_password@rabbitmq:5672/
UBCOMMUNICATOR_MONGODB_DSN=mongodb://ub_mongo_user:ub_mongo_pass@mongodb:27017/ubMessages
UBCOMMUNICATOR_COMMUNICATOR_ENVIRONMENT=dev
