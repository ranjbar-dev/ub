# ub-communicator environment variables
# Copy to .env and fill in production values.
# Viper reads these with prefix UBCOMMUNICATOR_ and dot→underscore mapping.

# General
UBCOMMUNICATOR_COMMUNICATOR_ENVIRONMENT=prod
UBCOMMUNICATOR_COMMUNICATOR_ALLOWED_IPS=127.0.0.1

# SMS (Twilio)
UBCOMMUNICATOR_SMS_ACCOUNT_SID=
UBCOMMUNICATOR_SMS_AUTH_TOKEN=
UBCOMMUNICATOR_SMS_FROM=

# MongoDB
UBCOMMUNICATOR_MONGODB_DSN=mongodb://user:password@localhost:27017/ubMessages/?authSource=admin

# RabbitMQ
UBCOMMUNICATOR_RABBITMQ_DSN=amqp://user:password@localhost:5672/

# Mail provider: smtp, sendgrid, mailjet, mailgun
UBCOMMUNICATOR_MAILER_BROKER=smtp

# SendGrid
UBCOMMUNICATOR_SENDGRID_API_KEY=

# Mailjet
UBCOMMUNICATOR_MAILJET_API_PUBLIC_KEY=
UBCOMMUNICATOR_MAILJET_API_PRIVATE_KEY=

# Mailgun
UBCOMMUNICATOR_MAILGUN_API_KEY=
UBCOMMUNICATOR_MAILGUN_DOMAIN=
UBCOMMUNICATOR_MAILGUN_API_BASE=https://api.eu.mailgun.net/v3

# SMTP
UBCOMMUNICATOR_SMTP_HOST=
UBCOMMUNICATOR_SMTP_PORT=587
UBCOMMUNICATOR_SMTP_USERNAME=
UBCOMMUNICATOR_SMTP_PASSWORD=

# Sentry
UBCOMMUNICATOR_SENTRY_DSN=
